{
  "name": "pharos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build && cap sync",
    "cap:open:ios": "npm run cap:sync && cap open ios",
    "cap:open:android": "npm run cap:sync && cap open android"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.10.0",
    "svelte": "^5.55.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4"
  }
}
